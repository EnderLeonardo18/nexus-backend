PORT=3000

# Configuración de Base de Datos MySQL
# DB_HOST=localhost

DB_HOST=127.0.0.1
DB_USER=root
DB_PASSWORD=
DB_DATABASE=nexus_db

# Seguridad de la Aplicación
JWT_SECRET=

